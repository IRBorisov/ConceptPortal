{
  "name": "frontend",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "scripts": {
    "generate": "lezer-generator src/features/rsform/components/rs-input/parse/rslang-fast.grammar -o src/features/rsform/components/rs-input/parse/parser.ts && lezer-generator src/features/rsform/components/refs-input/parse/refs-text.grammar -o src/features/rsform/components/refs-input/parse/parser.ts && lezer-generator src/features/ai/components/prompt-input/parse/prompt-text.grammar -o src/features/ai/components/prompt-input/parse/parser.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "pretest:e2e": "playwright install",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test",
    "test:e2e:ci": "playwright test",
    "dev": "vite --host",
    "build": "tsc && vite build",
    "lint": "stylelint \"src/**/*.css\" && eslint . --report-unused-disable-directives --max-warnings 0",
    "lintFix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"*.{ts,tsx}\"",
    "preview": "vite preview --port 3000"
  },
